{
    "help_and_support_button":{
        "locator": {
            "css selector": "button#help-support-button"
        }
    },
    "help_and_support_page_breadcrumb":{
        "locator": {
            "css selector": "[id='helpSupport'] [aria-current='page']"
        },
        "localization": {
            "en": "Help & Support"
        }
    },
    "help_and_support_page_header":{
        "locator": {
            "css selector": "#partner-help-and-support-header"
        },
        "localization": {
            "en": "Need assistance?"
        }
    },
    "help_and_support_page_header_description":{
        "locator": {
            "css selector": "h6"
        },
        "localization": {
            "en": "HP wants to help. Popular topics are here, or contact us about your specific need."
        }
    },
    "help_and_support_page_get_started_widget":{
        "locator": {
            "css selector": "div#get-started"
        }
    },
    "help_and_support_page_get_started_widget_title":{
        "locator": {
            "css selector": "#get-started h3 div>div"
        },
        "localization": {
            "en": "Get started"
        }
    },
    "help_and_support_page_get_started_widget_description":{
        "locator": {
            "css selector": "div#get-started p"
        },
        "localization": {
            "en": "Follow this guide for a quick start with HP Workforce Experience Platform"
        }
    },
    "help_and_support_page_get_started_widget_navigation_button":{
        "locator": {
            "css selector": "div#get-started > div:nth-of-type(2) svg"
