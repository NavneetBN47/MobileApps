{
    "remediations_secrets_page_breadcrumb":{
        "locator": {
            "css selector": "#SecretDetails span[aria-current='page']"
        }
    },
    "remediations_secrets_add_button":{
        "locator": {
            "xpath": "//span[contains(text(),'Add')]/parent::button"
        }
    },
    "add_secrets_page_title":{
        "locator": {
            "css selector": "p[class*='title-regular']"
        },
        "localization": {
            "en": "Add PC Secret"
        }
    },
    "add_secrets_page_cancel_button":{
        "locator": {
            "xpath": "//span[contains(text(),'Cancel')]/parent::button"
        }
    },
    "secrets_page_title":{
        "locator": {
            "css selector": "div[data-testid='wex-summary-card'] h3>div>div:nth-child(1)"
        }
    },
    "secrets_page_secret_name":{
        "locator": {
            "css selector": "div#wex-details-section-field-0 div[class*='editable-value'] div:nth-child(1)"
        }
    },
    "secrets_page_edit_button":{
        "locator": {
            "css selector": "div[class='col']>div:nth-child(1) button"
        }
    },
    "secrets_page_delete_button":{
        "locator": {
            "css selector": "button[data-testid='mobile-inlineBtns-0']"
        }
    }
}