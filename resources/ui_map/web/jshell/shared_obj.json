        }
    },
    "_shared_all_table_header_column":{
        "locator": {
            "css selector": "thead tr th"
        }
    },
    "_shared_table_all_col_by_index":{
        "locator": {
            "css selector": ["tr > td:nth-of-type({})  label+ span",
                            "tr > td:nth-of-type({})"]
        }
    },
    "_shared_table_first_row_all_cells": {
    "locator": {
