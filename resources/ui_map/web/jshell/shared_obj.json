{
    "_shared_page_nav_btn": {
        "locator": {
            "css selector": "button[aria-label*='age {}']"
        }
    }, 
    "_shared_page_prev_nav_btn": {
        "locator": {
            "css selector": ["button[aria-label='Previous']", "button[aria-label='Previous page']"]
        }
    },
    "_shared_page_next_nav_btn": {
        "locator": {
            "css selector": ["button[aria-label='Next']", "button[aria-label='Next page']"]
        }
    },
    "_shared_page_size_btn":{
        "locator": {
            "css selector": "button[aria-label='Select page size']"
        }
    },
    "_shared_page_size_total_txt":{
        "locator": {
            "css selector": "button[aria-label='Select page size'] ~ span"
        }
    },
    "_shared_page_size_menu_box": {
        "locator": {
            "css selector": ["[data-placement='top']",
                             "[data-placement='bottom']", 
                             "#pagination-dropdown"]
        }
    },
    "_shared_page_size_menu_entry":{
        "locator": {
            "css selector": "li[data-value='{}']"
        }
    },
    "_shared_page_size_menu_entry_new":{
        "locator": {
            "css selector": ["[aria-label='Select page size']+[role='presentation'] li",
                            "[data-placement='top'] li",
                            "button[role='menuitem']",
                            "#pagination-dropdown li",
                            "[role='presentation'] [data-placement='bottom'] li",
                            "#policies [data-placement='bottom'] li"]
        }
    },
    "_shared_page_size_menu_selected_entry":{
        "locator": {
            "css selector": "li[aria-selected='true']"
        }
    },
    "_shared_table_entries":{
        "locator": {
            "css selector": "tbody tr"
        }
    }, 
    "_shared_table_entry_all_cols":{
        "locator": {
            "css selector": "td"
        }
    },
    "_shared_table_entry_col_link":{
        "locator": {
            "css selector": "a"
        }
    },
    "_shared_table_entries_with_link":{
        "locator": {
            "css selector": "tbody tr td a"
        },
	"comment": "locator should be generic as it is shared by multiple teams"
    }, 
    "_shared_current_page":{
        "locator": {
            "css selector": ["button[aria-label*='(Current Page)']",
                           "button[aria-current='page']"]
        }
    },
    "_shared_all_pages_btn":{
        "locator": {
            "css selector": ["div[id='extended-0'] nav li",
                            "nav[aria-label='Table Pagination'] li",
                            "nav[aria-label='Pagination Navigation'] li",
                            "nav[aria-label*='paginationNavigation'] li",
                            "nav[aria-label='Pagination'] li",
                            "nav[aria-label='Pagination Navigation'] button",
                            "nav[aria-label='Table Pagination'] button"]
        }
    },
    "_shared_no_items_found_img":{
        "locator": {
            "css selector": ["tbody tr td div div svg",
                            "#policies svg[aria-label='Warning Alt']",
