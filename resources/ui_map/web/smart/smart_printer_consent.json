                    "id": "title-text"}
    },
    "accept_all_btn":{
        "locator": {"css selector": ["#consent-button","#consent-accept-all-button"],
                    "id": "consent-accept-all-button"}
    },
    "manage_option_btn":{
        "locator": {"css selector": "#consent-continue-button",
            "id": "consent-manage=options-button"}
    },
