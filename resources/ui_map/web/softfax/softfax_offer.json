    "locator": {
      "css selector": "input#nameInput",
      "id": "nameInput"
    }
  },
  "email_value": {
    "locator": {
      "css selector": "input#emailInput",
      "id": "emailInput"
    }
  },
  "entity_value": {
    "locator": {
      "css selector": "input#coveredEntityInput",
      "id": "coveredEntityInput"
    }
  },
  "date_value": {
    "locator": {
      "css selector": "input#dateInput",
      "id": "dateInput"
    }
  },
  "accept_agreement": {
    "locator": {
      "css selector": "span#baaCheckboxLabelContainer"
    }
