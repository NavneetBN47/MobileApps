      "xpath": "//XCUIElementTypeOther[contains(@label, 'Try the mobile way')]/following-sibling::XCUIElementTypeGroup/XCUIElementTypeStaticText[@value='Get Started']",
      "css selector": "#getStartedHero"
    }
  },
