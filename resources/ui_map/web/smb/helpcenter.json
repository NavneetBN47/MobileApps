{
    "helpcenter_title":{
        "locator": {
            "css selector": "div[class*='smb-help-center'] span[class*='subtitle-regular']"
        },
        "localization": {
            "en": "Help Center"
        }
    },
    "sideMenuContent_title":{
        "locator": {
            "css selector": "h1[data-testid='sidenavcontent-title']"
        }
    },
    "sideMenuContent_text":{
        "locator": {
            "xpath": "//*[@id='sideMenuContent']/text()"
        }
    },
    "printing_title":{
        "locator": {
            "xpath": ["//li[@data-testid='sideMenuItem']/a/div[contains(text(),'Printing')]",
                     "//li[@data-testid='printing']/a/span[contains(text(),'Printing')]"]
        },
        "localization": {
            "en": "Printing"
        }
    },
