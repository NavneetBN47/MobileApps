{
  "@hp-af/logging/transports": "fileAsyncTransport",
  "@hp-af/logging/severity": "debug",
  "@env/APP_MODE": "rebrand",
  "@env/DEBUG_TOOLS": "true",
  "@hp-af-jarvis-auth/forceLogsAuth": "true",
  "@env/JARVIS_LOGS_ENABLED": "true",
  "@hp-af/feature-switch/overrides": 
  {
    "apptelemetry-stopwatch": true,
    "devices-x-adddevice": true,
    "devices-x-add-printer": true,
    "devices-x-add-networkprinter": true,
    "devices-x-add-setupprinter": true,
    "devices-x-add-devicesupport": true,
    "printer-x-nativeshell": true
  }
}

